{
  "name": "atlas-cli",
  "version": "0.1.0",
  "description": "Atlas CLI - 斑马云图人力基线管理工具",
  "private": true,
  "type": "module",
  "bin": {
    "atlas": "./dist/adapters/atlas/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "node ./dist/adapters/atlas/cli.js --help",
    "recon": "node --import tsx ./scripts/recon.ts",
    "auth:login": "node --import tsx ./adapters/atlas/cli.ts auth login"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "exceljs": "^4.4.0",
    "keytar": "^7.9.0",
    "nunjucks": "^3.2.4",
    "papaparse": "^5.5.3",
    "playwright": "^1.49.0",
    "undici": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nunjucks": "^3.2.6",
    "@types/papaparse": "^5.5.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
